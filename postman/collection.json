          "name": "Get user by id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response < 1s\", () => {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Schema valid\", () => {\r",
                  "    const d = pm.response.json();\r",
                  "    pm.expect(d).to.have.property(\"id\");\r",
                  "    pm.expect(d).to.have.property(\"email\");\r",
                  "    pm.expect(d.id).to.be.a(\"number\");\r",
                  "    pm.expect(d.email).to.match(/@/);\r",
                  "    pm.expect(d).to.have.property(\"name\");\r",
                  "    pm.expect(d.name).to.be.a(\"string\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Content-Type JSON\", () => {\r",
                  "    pm.response.to.have.header(\"Content-Type\");\r",

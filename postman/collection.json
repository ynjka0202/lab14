      "name": "Users",
      "item": [
        {
          "name": "List users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response < 1s\", () => {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Body array байна\", () => {\r",
                  "    const d = pm.response.json();\r",
                  "    pm.expect(d).to.be.an(\"array\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"10 user байна\", () => {\r",
                  "    const d = pm.response.json();\r",
                  "    pm.expect(d).to.have.lengthOf(10);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Content-Type JSON\", () => {\r",
                  "    pm.response.to.have.header(\"Content-Type\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            }
